window-inherit-working-directory = true

# Use xterm-256color so remote machines recognize the terminal over SSH
# (prevents white-only text when SSHing into servers)
term = xterm-256color

# Move focus between splits with Option + Cmd + Arrows
keybind = option+cmd+up=goto_split:up
keybind = option+cmd+down=goto_split:down
keybind = option+cmd+left=goto_split:left
keybind = option+cmd+right=goto_split:right
